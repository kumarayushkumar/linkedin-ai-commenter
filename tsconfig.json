{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext", // Updated to ESNext for compatibility with Manifest V3
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["chrome"],
    "lib": ["es2017", "dom"],
    "outDir": "dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
